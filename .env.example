# Server
PORT=3000
NODE_ENV=development

# Database (local dev uses file:resenas.db when unset)
# Production on Vercel: use Turso (see DEPLOY.md)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Optional alias for non-Turso libsql URLs
DATABASE_URL=

# Admin panel (required in production)
ADMIN_USER=
ADMIN_PASSWORD=
SESSION_SECRET=

# Google review redirect (pick one)
GOOGLE_PLACE_ID=
GOOGLE_REVIEW_URL=
